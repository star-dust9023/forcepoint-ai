# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LiteLLM proxy ──────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-...
LITELLM_BASE_URL=http://localhost:4000
CLAUDE_MODEL=claude-sonnet

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LangSmith ──────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=forcepoint-enterprise-ai

# ── Azure / M365 ───────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Atlassian / Jira — OAuth 3LO ───────────────────────────────────────────────
# Register at: developer.atlassian.com → Your apps → OAuth 2.0 (3LO)
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
ATLASSIAN_OAUTH_REDIRECT_URI=https://your-agent.fpdev.io/auth/jira/callback
JIRA_DEFAULT_PROJECT=AI

# ── Salesforce via CData Connect AI ────────────────────────────────────────────
CDATA_BASE_URL=
CDATA_API_KEY=

# Create one CData connection per SF profile tier in the CData Connect AI portal
CDATA_CONNECTION_SALES=Salesforce_Sales
CDATA_CONNECTION_OPS=Salesforce_Ops
CDATA_CONNECTION_DEFAULT=Salesforce

# ── GitHub Skills Repo ─────────────────────────────────────────────────────────
SKILLS_REPO_BASE_URL=https://github.cicd.cloud.fpdev.io/raw/BTS/claude-skills/main/docs
SKILLS_GITHUB_TOKEN=
SKILLS_CACHE_TTL=3600

# ── Entra group → department mapping ───────────────────────────────────────────
# Paste Object IDs from Azure AD → Groups
ENTRA_GROUP_SALES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_GROUP_ENG=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_GROUP_FINANCE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
